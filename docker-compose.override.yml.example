# duplicate this override.yml to add your own folders into the app.
services:
  api:
    # you can find your GOONCAVE_USER_ID under gooncave-library, after registering.
    # The real host folder still must allow Docker to write into it,
    # or uploads and favorites sync will fail. check README for further instructions.
    volumes:
      - ${LOCAL_MEDIA_DIR}:/gooncave-library/users/${GOONCAVE_USER_ID}/downloads
  worker:
    # Keep the same mount here so background scans and favorite downloads
    volumes:
      - ${LOCAL_MEDIA_DIR}:/gooncave-library/users/${GOONCAVE_USER_ID}/downloads
